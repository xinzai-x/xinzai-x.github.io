<!--
  Cleartext Theme — Diagnostic Test Page
  将此文件放入 Hexo 项目的 source/ 目录，然后运行 hexo server 验证主题渲染
-->
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cleartext Theme — 诊断测试</title>
  <link rel="stylesheet" href="css/style.css">
  <style>
    body { font-family: var(--font-sans, sans-serif); background: var(--color-bg, #fff); color: var(--color-text, #333); padding: 2rem; }
    .test-section { background: var(--color-bg-elevated, #fff); border: 1px solid var(--color-border, #ddd); border-radius: var(--radius-lg, 8px); padding: 1.5rem; margin-bottom: 1rem; }
    .pass { color: #10b981; font-weight: bold; }
    .fail { color: #ef4444; font-weight: bold; }
    .warn { color: #f59e0b; font-weight: bold; }
    h2 { margin-top: 0; }
    pre { background: #f1f5f9; padding: 1rem; border-radius: 4px; overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
    th, td { border: 1px solid #e2e8f0; padding: 0.5rem; text-align: left; }
    th { background: #f8fafc; }
  </style>
</head>
<body>
  <main style="max-width: 900px; margin: 0 auto;">

    <div class="test-section">
      <h2>1. CSS 变量加载测试</h2>
      <p>背景色: <span id="bg-test" style="padding:4px 8px;border-radius:4px;">计算中...</span></p>
      <p>主文字色: <span id="text-test" style="padding:4px 8px;border-radius:4px;">计算中...</span></p>
      <p>强调色: <span id="accent-test" style="padding:4px 8px;border-radius:4px;">计算中...</span></p>
      <p id="css-result"></p>
    </div>

    <div class="test-section">
      <h2>2. Grid 布局测试</h2>
      <div id="grid-test-container" style="display:grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem;">
        <div style="background:var(--color-accent-light, #e0f2fe); padding:1rem; text-align:center; border-radius:4px;">列 1</div>
        <div style="background:var(--color-accent-light, #e0f2fe); padding:1rem; text-align:center; border-radius:4px;">列 2</div>
        <div style="background:var(--color-accent-light, #e0f2fe); padding:1rem; text-align:center; border-radius:4px;">列 3</div>
      </div>
    </div>

    <div class="test-section">
      <h2>3. 排版测试</h2>
      <h3>三级标题</h3>
      <p>正文段落 — <strong>加粗文字</strong> — <em>斜体文字</em> — <code>行内代码</code></p>
      <blockquote>这是一个引用块。Cleartext 主题支持 Markdown 所有标准格式。</blockquote>

      <pre><code>// 代码块测试
function hello() {
  console.log("Hello, Cleartext!");
}</code></pre>
    </div>

    <div class="test-section">
      <h2>4. 表格测试</h2>
      <table>
        <thead><tr><th>功能</th><th>状态</th><th>说明</th></tr></thead>
        <tbody>
          <tr><td>公式</td><td>支持</td><td>MathJax 3 / KaTeX</td></tr>
          <tr><td>分栏</td><td>支持</td><td>{% columns %} 短代码</td></tr>
          <tr><td>暗色模式</td><td>支持</td><td>自动 / 手动切换</td></tr>
          <tr><td>搜索</td><td>支持</td><td>search.xml 全文检索</td></tr>
          <tr><td>TOC</td><td>支持</td><td>桌面端固定 / 移动端折叠</td></tr>
        </tbody>
      </table>
    </div>

    <div class="test-section">
      <h2>5. JS 资源加载状态</h2>
      <ul id="js-status">
        <li>main.js: <span id="js-main">检查中...</span></li>
        <li>dark-mode.js: <span id="js-dark">检查中...</span></li>
        <li>search.js: <span id="js-search">检查中...</span></li>
      </ul>
    </div>
  </main>

  <script>
    (function() {
      // CSS 变量检测
      var bg = getComputedStyle(document.body).getPropertyValue('--color-bg').trim();
      var text = getComputedStyle(document.body).getPropertyValue('--color-text').trim();
      var accent = getComputedStyle(document.body).getPropertyValue('--color-accent').trim();
      var result = document.getElementById('css-result');
      var allPassed = true;

      var bgEl = document.getElementById('bg-test');
      var textEl = document.getElementById('text-test');
      var accentEl = document.getElementById('accent-test');

      if (bg) { bgEl.textContent = bg; bgEl.style.backgroundColor = bg; bgEl.style.color = text || '#333'; }
      else { bgEl.innerHTML = '<span class="fail">FAIL</span>'; allPassed = false; }

      if (text) { textEl.textContent = text; textEl.style.backgroundColor = text; textEl.style.color = bg || '#fff'; }
      else { textEl.innerHTML = '<span class="fail">FAIL</span>'; allPassed = false; }

      if (accent) { accentEl.textContent = accent; accentEl.style.backgroundColor = accent; accentEl.style.color = '#fff'; }
      else { accentEl.innerHTML = '<span class="fail">FAIL</span>'; allPassed = false; }

      result.innerHTML = allPassed
        ? '<span class="pass">全部通过: CSS 变量加载正常</span>'
        : '<span class="fail">部分失败: CSS 变量未加载，检查 style.css 路径</span>';
    })();
  </script>
</body>
</html>