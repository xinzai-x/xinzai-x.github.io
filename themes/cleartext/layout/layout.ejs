<!DOCTYPE html>
<html lang="<%= config.language || 'zh-CN' %>" class="<%= (theme.dark_mode && theme.dark_mode.default === 'dark') ? 'dark' : '' %>">
<head>
  <%- partial('partial/head') %>
</head>
<body>
  <a href="#main-content" class="skip-to-content" aria-label="跳转到主要内容">跳到内容</a>
  <%- partial('partial/header') %>

  <div class="page-shell" id="main-content">
    <div class="grid-container
      <% if (is_post() || is_home()) { %>grid-post<% } %>
      <% if (is_home() && theme.sidebar && theme.sidebar.enable) { %>grid-has-sidebar<% } %>
      <% if (!is_post() && !is_home()) { %>grid-page<% } %>
    ">
      <main class="grid-main">
        <%- body %>
      </main>

      <% if (is_home() && theme.sidebar && theme.sidebar.enable) { %>
      <aside class="grid-sidebar">
        <%- partial('partial/sidebar') %>
      </aside>
      <% } %>
    </div>
  </div>

  <%- partial('partial/footer') %>

  <script defer src="<%= url_for('/js/main.js') %>"></script>
  <%- partial('partial/scripts') %>
</body>
</html>