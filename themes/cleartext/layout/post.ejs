<%
var wordCount = 0;
var readingTime = '';
var updated = '';
if (post.updated && post.updated !== post.date) {
  updated = '更新于 ' + full_date(post.updated, theme.article.date_format || 'YYYY-MM-DD');
}
%>

<article class="post-full" itemscope itemtype="http://schema.org/Article">

  <header class="post-header">
    <!-- Breadcrumb Navigation -->
    <nav class="breadcrumb" aria-label="面包屑导航">
      <a href="<%= url_for('/') %>">首页</a>
      <span class="breadcrumb-sep">/</span>
      <% if (post.categories && post.categories.length > 0) { %>
        <a href="<%= url_for(post.categories.first().path) %>"><%= post.categories.first().name %></a>
        <span class="breadcrumb-sep">/</span>
      <% } %>
      <span class="breadcrumb-current" aria-current="page"><%= truncate(post.title, 50) %></span>
    </nav>

    <h1 class="post-title" itemprop="headline"><%= post.title %></h1>

    <div class="post-meta">
      <span class="meta-item" itemprop="datePublished" content="<%= date_xml(post.date) %>">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <time datetime="<%= date_xml(post.date) %>"><%= full_date(post.date, theme.article.date_format || 'YYYY-MM-DD') %></time>
      </span>
      <% if (post.author) { %>
      <span class="meta-item" itemprop="author" itemscope itemtype="http://schema.org/Person">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        <span itemprop="name"><%= post.author %></span>
      </span>
      <% } %>
      <span class="meta-item meta-stats">
        <span class="word-count"><%= post.word_count || 0 %> 字</span>
        <span class="reading-time"><%= post.reading_time || '' %></span>
      </span>
      <% if (updated) { %>
      <span class="meta-updated"><%= updated %></span>
      <% } %>
    </div>

    </header>

  <!-- Desktop TOC (collapsible, above content) -->
  <% if (theme.toc && theme.toc.enable) { %>
  <div class="toc-desktop-collapsible" id="toc-desktop-wrapper" aria-label="文章目录">
    <details id="toc-desktop-details">
      <summary class="toc-desktop-toggle" aria-label="展开/收起目录">
        <svg class="toc-toggle-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="8" y1="6" x2="21" y2="6"></line>
          <line x1="8" y1="12" x2="21" y2="12"></line>
          <line x1="8" y1="18" x2="21" y2="18"></line>
          <line x1="3" y1="6" x2="3.01" y2="6"></line>
          <line x1="3" y1="12" x2="3.01" y2="12"></line>
          <line x1="3" y1="18" x2="3.01" y2="18"></line>
        </svg>
        文章目录
      </summary>
      <nav class="toc" id="toc-desktop" aria-label="文章目录"></nav>
    </details>
  </div>
  <% } %>

  <!-- Mobile TOC (collapsible) -->
  <% if (theme.toc && theme.toc.enable) { %>
  <div class="toc-mobile" id="toc-mobile-wrapper" aria-label="移动端文章目录">
    <details id="toc-mobile-details">
      <summary class="toc-mobile-toggle" aria-label="展开/收起目录">文章目录</summary>
      <nav class="toc" id="toc-mobile" aria-label="文章目录"></nav>
    </details>
  </div>
  <% } %>

  <!-- Post Content -->
  <div class="post-content" itemprop="articleBody">
    <%- post.content %>
  </div>



</article>

<!-- Giscus Comments -->
<% if (theme.comments && theme.comments.giscus && theme.comments.giscus.enable) { %>
<div class="giscus-placeholder" id="giscus-placeholder">
  <p>评论区由 Giscus 驱动，点击下方按钮加载</p>
  <button id="load-giscus-btn" aria-label="加载评论区">加载评论</button>
</div>
<div id="giscus-container" style="display:none;"></div>
<% } %>

<!-- Post Navigation -->
<% if (theme.post_nav && theme.post_nav.enable !== false) { %>
<nav class="post-nav" aria-label="文章导航">
  <% var prevPost = post.prev ? post.prev : false; %>
  <div class="post-nav-prev">
    <% if (prevPost) { %>
    <a href="<%= url_for(prevPost.path) %>" class="post-nav-link">
      <span class="post-nav-label">&#8592; 上一篇</span>
      <%= prevPost.title %>
    </a>
    <% } %>
  </div>
  <% var nextPost = post.next ? post.next : false; %>
  <div class="post-nav-next">
    <% if (nextPost) { %>
    <a href="<%= url_for(nextPost.path) %>" class="post-nav-link">
      <span class="post-nav-label">下一篇 &#8594;</span>
      <%= nextPost.title %>
    </a>
    <% } %>
  </div>
</nav>
<% } %>

<!-- Back-to-top & back-to-bottom floating buttons -->
<button class="back-to-top" id="back-to-top" aria-label="回到顶部" title="回到顶部">
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <line x1="12" y1="19" x2="12" y2="5"></line>
    <polyline points="5 12 12 5 19 12"></polyline>
  </svg>
</button>
<button class="back-to-bottom" id="back-to-bottom" aria-label="直达底部" title="直达底部">
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <line x1="12" y1="5" x2="12" y2="19"></line>
    <polyline points="19 12 12 19 5 12"></polyline>
  </svg>
</button>

<!-- Image Lightbox -->
<div class="lightbox-overlay" id="lightbox" aria-hidden="true">
  <button class="lightbox-close" id="lightbox-close" aria-label="关闭">&times;</button>
  <button class="lightbox-prev" id="lightbox-prev" aria-label="上一张">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <button class="lightbox-next" id="lightbox-next" aria-label="下一张">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
  <img id="lightbox-img" src="" alt="" />
  <span class="lightbox-counter" id="lightbox-counter"></span>
</div>
