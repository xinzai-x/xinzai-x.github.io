<div class="posts-grid">
<% page.posts.each(function(post) { %>
<article class="post-card" itemscope itemtype="http://schema.org/Article">
  <h2 class="post-card-title" itemprop="headline">
    <% if (post.top && post.top !== false && post.top !== 'false') { %><span class="sticky-badge"><svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M16 9V4h1c.55 0 1-.45 1-1s-.45-1-1-1H7c-.55 0-1 .45-1 1s.45 1 1 1h1v5c0 1.66-1.34 3-3 3v2h5.97v7l1 1 1-1v-7H19v-2c-1.66 0-3-1.34-3-3z"/></svg>置顶</span><% } %>
    <a href="<%= url_for(post.path) %>" itemprop="url"><%= post.title %></a>
  </h2>

  <div class="post-card-meta">
    <span class="post-card-date" itemprop="datePublished" content="<%= date_xml(post.date) %>">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      <time datetime="<%= date_xml(post.date) %>"><%= full_date(post.date, theme.article.date_format || 'YYYY-MM-DD') %></time>
    </span>
    <% if (post.updated && post.updated !== post.date) { %>
    <span class="post-card-updated">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M21 12A9 9 0 0 0 6 6L1 10"/><path d="M3 12a9 9 0 0 0 15 6l5-4"/></svg>
      更新于 <%= full_date(post.updated, theme.article.date_format || 'YYYY-MM-DD') %>
    </span>
    <% } %>
  </div>

  <% if (post.excerpt) { %>
  <% if (!post.password || post.password === '') { %>
  <div class="post-card-excerpt">
    <%= strip_html(post.excerpt) %>
  </div>
  <% } else { %>
  <div class="post-card-excerpt post-card-excerpt-locked">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
    此文章已加密
  </div>
  <% } %>
  <% } %>

  <% if (post.categories && post.categories.length > 0 || post.tags && post.tags.length > 0) { %>
  <div class="post-card-meta-bottom">
    <% if (post.categories && post.categories.length > 0) { %>
    <% post.categories.each(function(cat) { %>
    <a href="<%= url_for(cat.path) %>" class="category-badge"><%= cat.name %></a>
    <% }); %>
    <% } %>
    <% if (post.tags && post.tags.length > 0) { %>
    <% post.tags.each(function(tag) { %>
    <a href="<%= url_for(tag.path) %>" class="tag-badge"><%= tag.name %></a>
    <% }); %>
    <% } %>
  </div>
  <% } %>
</article>
<% }); %>
</div>

<!-- Pagination -->
<% if (page.total > 1) { %>
<%- partial('partial/pagination') %>
<% } %>
