<div class="page-about">
  <div class="about-hero">
    <div class="about-profile">
      <div class="about-avatar-placeholder">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
      </div>
      <h1 class="about-name"><%= page.title %></h1>
      <p class="about-tagline">记录技术与生活的思考</p>
    </div>
  </div>

  <div class="about-body">
    <div class="about-bio">
      <%- page.content %>
    </div>

    <div class="about-stats-bar">
      <div class="stat-entry">
        <span class="stat-value" id="about-post-count"><%= site.posts.length %></span>
        <span class="stat-key">文章</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-entry">
        <span class="stat-value" id="about-tag-count"><%= site.tags.length %></span>
        <span class="stat-key">标签</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-entry">
        <span class="stat-value" id="about-cat-count"><%= site.categories.length %></span>
        <span class="stat-key">分类</span>
      </div>
    </div>

    <div class="about-skills-section">
      <div class="skills-group">
        <span class="skill-pill">JavaScript</span>
        <span class="skill-pill">TypeScript</span>
        <span class="skill-pill">React</span>
        <span class="skill-pill">Vue</span>
        <span class="skill-pill">Node.js</span>
        <span class="skill-pill">Python</span>
        <span class="skill-pill">Go</span>
        <span class="skill-pill">Docker</span>
        <span class="skill-pill">Kubernetes</span>
      </div>
    </div>

    <div class="about-social">
      <a href="https://github.com/yourusername" class="social-link" target="_blank" rel="noopener" title="GitHub">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
        </svg>
      </a>
      <a href="mailto:hello@example.com" class="social-link" title="Email">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
      </a>
      <a href="#" class="social-link" title="RSS">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 11a9 9 0 0 1 9 9"></path>
          <path d="M4 4a16 16 0 0 1 16 16"></path>
          <circle cx="5" cy="19" r="1"></circle>
        </svg>
      </a>
    </div>
  </div>
</div>