<div class="page-about">
  <div class="about-hero">
    <div class="about-avatar">
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
        <circle cx="12" cy="7" r="4"></circle>
      </svg>
    </div>
    <div class="about-hero-text">
      <h1 class="about-name"><%= page.title %></h1>
      <% if (config.description) { %>
      <p class="about-tagline"><%= config.description %></p>
      <% } %>
    </div>
  </div>

  <div class="about-stats">
    <div class="about-stat">
      <span class="about-stat-num"><%= site.posts.length %></span>
      <span class="about-stat-label">文章</span>
    </div>
    <div class="about-stat">
      <span class="about-stat-num"><%= site.categories.length %></span>
      <span class="about-stat-label">分类</span>
    </div>
    <div class="about-stat">
      <span class="about-stat-num"><%= site.tags.length %></span>
      <span class="about-stat-label">标签</span>
    </div>
  </div>

  <div class="about-bio">
    <%- page.content %>
  </div>

  <% if (site.categories && site.categories.length > 0) { %>
  <div class="about-categories">
    <% site.categories.sort('name').each(function(cat) { %>
    <a href="<%= url_for(cat.path) %>" class="about-cat-pill">
      <%= cat.name %>
      <span class="about-cat-count"><%= cat.posts.length %></span>
    </a>
    <% }); %>
  </div>
  <% } %>

  <% if (theme.social) { %>
  <div class="about-social">
    <% if (theme.social.github) { %>
    <a href="<%= theme.social.github %>" class="about-social-link" target="_blank" rel="noopener" title="GitHub">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
    </a>
    <% } %>
    <% if (theme.social.email) { %>
    <a href="mailto:<%= theme.social.email %>" class="about-social-link" title="Email">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
    </a>
    <% } %>
    <% if (theme.social.rss) { %>
    <a href="<%= theme.social.rss %>" class="about-social-link" title="RSS">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
    </a>
    <% } %>
  </div>
  <% } %>
</div>
