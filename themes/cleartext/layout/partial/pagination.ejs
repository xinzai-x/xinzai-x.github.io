<% if (page.total > 1) { %>
<nav class="pagination" aria-label="分页导航">
  <%
    var currentPage = page.current;
    var totalPages = page.total;
    var pageDir = config.pagination_dir || 'page';

    function pageUrl(n) {
      if (n === 1) return '/';
      return '/' + pageDir + '/' + n + '/';
    }
  %>

  <% /* Previous */ %>
  <% if (currentPage > 1) { %>
  <a href="<%= url_for(pageUrl(currentPage - 1)) %>" class="pagination-item" aria-label="上一页">&laquo;</a>
  <% } %>

  <% /* Page numbers with ellipsis */ %>
  <%
    var range = 2;
    var start = Math.max(1, currentPage - range);
    var end = Math.min(totalPages, currentPage + range);

    if (start > 1) { %>
      <a href="<%= url_for(pageUrl(1)) %>" class="pagination-item">1</a>
      <% if (start > 2) { %><span class="pagination-item pagination-ellipsis">...</span><% } %>
    <% }

    for (var i = start; i <= end; i++) {
      if (i === currentPage) { %>
        <span class="pagination-item pagination-current" aria-current="page"><%= i %></span>
      <% } else { %>
        <a href="<%= url_for(pageUrl(i)) %>" class="pagination-item"><%= i %></a>
      <% }
    }

    if (end < totalPages) { %>
      <% if (end < totalPages - 1) { %><span class="pagination-item pagination-ellipsis">...</span><% } %>
      <a href="<%= url_for(pageUrl(totalPages)) %>" class="pagination-item"><%= totalPages %></a>
    <% }
  %>

  <% /* Next */ %>
  <% if (currentPage < totalPages) { %>
  <a href="<%= url_for(pageUrl(currentPage + 1)) %>" class="pagination-item" aria-label="下一页">&raquo;</a>
  <% } %>
</nav>
<% } %>
