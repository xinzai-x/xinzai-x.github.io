<footer class="site-footer" role="contentinfo">
  <div class="footer-inner">
    <% if (theme.social && (theme.social.github || theme.social.twitter || theme.social.email || theme.social.rss)) { %>
    <div class="footer-social">
      <% if (theme.social.github) { %>
      <a href="<%= theme.social.github %>" class="social-link" aria-label="GitHub" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
        </svg>
      </a>
      <% } %>
      <% if (theme.social.twitter) { %>
      <a href="<%= theme.social.twitter %>" class="social-link" aria-label="Twitter" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
        </svg>
      </a>
      <% } %>
      <% if (theme.social.email) { %>
      <a href="mailto:<%= theme.social.email %>" class="social-link" aria-label="Email" target="_blank" rel="noopener noreferrer" aria-label="Email">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
      </a>
      <% } %>
      <% if (theme.social.rss) { %>
      <a href="<%= theme.social.rss %>" class="social-link" aria-label="RSS" target="_blank" rel="noopener noreferrer" aria-label="RSS">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 11a9 9 0 0 1 9 9"></path>
          <path d="M4 4a16 16 0 0 1 16 16"></path>
          <circle cx="5" cy="19" r="1"></circle>
        </svg>
      </a>
      <% } %>
    </div>
    <% } %>

    <% var currentYear = new Date().getFullYear(); %>
    <% if (theme.footer && theme.footer.copyright !== false) { %>
    <div class="footer-copyright">
      &copy; <% if (theme.footer.since && theme.footer.since < currentYear) { %><%= theme.footer.since %>-<% } %><%= currentYear %> <%= config.author || config.title %>.
      <% if (theme.footer.powered !== false) { %>
      <span class="footer-powered">
        由 <a href="https://hexo.io/" target="_blank" rel="noopener" aria-label="Hexo">Hexo</a> 和 <a href="https://github.com/yourname/hexo-theme-cleartext" target="_blank" rel="noopener" aria-label="Cleartext Theme">Cleartext</a> 驱动。
      </span>
      <% } %>
    </div>
    <% } %>
  </div>
</footer>
