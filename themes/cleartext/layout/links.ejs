<div class="page-links">
  <h1 class="page-title"><%= page.title %></h1>

  <% if (page.content && page.content.trim()) { %>
  <div class="post-content" style="margin-bottom: var(--space-8);">
    <%- page.content %>
  </div>
  <% } %>

  <% 
  // 支持两种格式：links.yml（新）和 link.yml（旧）
  var linkData = [];
  var categories = [];
  
  if (site.data && site.data.links) {
    // 新格式：links.yml
    linkData = site.data.links;
  } else if (site.data && site.data.link) {
    // 旧格式：link.yml
    categories = site.data.link;
  }
  
  if (categories.length > 0) { 
    categories.forEach(function(category) {
      if (category.link_list && category.link_list.length > 0) {
  %>
  <section class="link-category">
    <div class="link-category-header">
      <h2 class="link-category-title"><%= category.class_name %></h2>
      <% if (category.class_desc) { %>
      <p class="link-category-desc"><%= category.class_desc %></p>
      <% } %>
    </div>
    
    <% if (category.flink_style === 'anzhiyu') { %>
    <div class="link-list anzhiyu-style">
      <% category.link_list.forEach(function(link) { %>
      <a href="<%= link.link %>" class="link-item anzhiyu-link" target="_blank" rel="noopener noreferrer" title="<%= link.descr || link.name %>">
        <div class="link-item-header">
          <% if (link.avatar) { %>
          <img class="link-avatar" src="<%= link.avatar %>" alt="<%= link.name %>" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
          <% } %>
          <div class="link-avatar-placeholder" <% if (link.avatar) { %>style="display:none;"<% } %>>
            <%= link.name.charAt(0).toUpperCase() %>
          </div>
          <div class="link-info">
            <div class="link-name"><%= link.name %></div>
            <% if (link.descr) { %>
            <div class="link-desc"><%= link.descr %></div>
            <% } %>
          </div>
          <% if (link.recommend) { %>
          <div class="link-recommend-tag">推荐</div>
          <% } %>
        </div>
      </a>
      <% }); %>
    </div>
    <% } else { %>
    <div class="link-list">
      <% category.link_list.forEach(function(link) { %>
      <a href="<%= link.link %>" class="link-item" target="_blank" rel="noopener noreferrer" title="<%= link.descr || link.name %>">
        <div class="link-item-header">
          <% if (link.avatar) { %>
          <img class="link-avatar" src="<%= link.avatar %>" alt="<%= link.name %>" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
          <% } %>
          <div class="link-avatar-placeholder" <% if (link.avatar) { %>style="display:none;"<% } %>>
            <%= link.name.charAt(0).toUpperCase() %>
          </div>
          <div class="link-info">
            <div class="link-name"><%= link.name %></div>
            <% if (link.descr) { %>
            <div class="link-desc"><%= link.descr %></div>
            <% } %>
          </div>
        </div>
      </a>
      <% }); %>
    </div>
    <% } %>
  </section>
  <% 
      }
    });
  } else if (linkData.length > 0) { 
  %>
  <div class="link-list">
    <% linkData.forEach(function(link) { %>
    <a href="<%= link.url %>" class="link-item" target="_blank" rel="noopener noreferrer" title="<%= link.description || link.title %>">
      <div class="link-item-header">
        <% if (link.avatar) { %>
        <img class="link-avatar" src="<%= link.avatar %>" alt="<%= link.title %>" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
        <% } %>
        <div class="link-avatar-placeholder" <% if (link.avatar) { %>style="display:none;"<% } %>>
          <%= link.title.charAt(0).toUpperCase() %>
        </div>
        <div class="link-info">
          <div class="link-name"><%= link.title %></div>
          <% if (link.description) { %>
          <div class="link-desc"><%= link.description %></div>
          <% } %>
        </div>
      </div>
    </a>
    <% }); %>
  </div>
  <% } else { %>
  <div class="post-content">
    <p>友链数据请放在 <code>source/_data/links.yml</code>，格式：</p>
    <pre><code>- title: 网站名称
  url: https://example.com
  avatar: https://example.com/avatar.png
  description: 一句话描述</code></pre>
  </div>
  <% } %>
</div>
