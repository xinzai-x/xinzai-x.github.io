<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <p class="copyright">
        &copy; <%= date(new Date(), 'YYYY') %> <a href="<%- url_for('/') %>"><%= config.title %></a>
      </p>
      <% if (config.author) { %>
        <p class="author"><%= config.author %></p>
      <% } %>
    </div>
    <div class="footer-right">
      <% if (theme.social) { %>
        <nav class="footer-social">
          <% for (var name in theme.social) { %>
            <a href="<%- url_for(theme.social[name]) %>" target="_blank" rel="noopener" aria-label="<%= name %>">
              <% if (name === 'GitHub') { %>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              <% } else if (name === '抖音') { %>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.87a8.16 8.16 0 004.77 1.52V6.95a4.84 4.84 0 01-.97-.26z"/></svg>
              <% } else if (name === 'Email') { %>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              <% } else if (name === 'RSS') { %>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>
              <% } else { %>
                <span><%= name %></span>
              <% } %>
            </a>
          <% } %>
        </nav>
      <% } %>
      <p class="powered-by">
        Powered by <a href="https://hexo.io/" target="_blank" rel="noopener">Hexo</a>
        &middot; Theme <a href="https://github.com" target="_blank" rel="noopener">Ink</a>
      </p>
    </div>
  </div>
</footer>
